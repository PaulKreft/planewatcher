# Where you are
WATCH_LAT=50.9375
WATCH_LON=6.9603
WATCH_RADIUS_KM=50

# Slack incoming webhook (same pattern as your Stripe pipeline)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Shared secret for external cron pingers (Hobby plan workaround)
CRON_SECRET=generate-a-long-random-string

# Upstash Redis — auto-injected if you add the Vercel integration,
# otherwise paste these from the Upstash console
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# OpenSky credentials (free account at opensky-network.org)
# Without these you'll hit rate limits within an hour
OPENSKY_USER=your-username
OPENSKY_PASS=your-password
