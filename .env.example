# Where you are
WATCH_LAT=50.9375
WATCH_LON=6.9603
WATCH_RADIUS_KM=50

# Slack incoming webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Shared secret for cron-job.org pinger
CRON_SECRET=generate-a-long-random-string

# Password for the web dashboard (you'll type this once in the browser)
ADMIN_PASSWORD=another-long-random-string

# Upstash Redis — auto-injected if you add the Vercel integration
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# OpenSky OAuth2 client credentials
# Create at: https://opensky-network.org/ → Account page → "API clients"
OPENSKY_CLIENT_ID=your-client-id
OPENSKY_CLIENT_SECRET=your-client-secret
# If token requests ETIMEDOUT from Vercel, route OpenSky calls through a proxy that can reach auth.opensky-network.org (CONNECT URL, often http://… even for HTTPS targets).
# OPENSKY_HTTPS_PROXY=http://127.0.0.1:8443
